{
  "name": "creatorsync",
  "version": "2.0.0",
  "description": "CreatorSync - Enterprise-grade music monetization platform for producers and artists. Features beat marketplace, real-time collaboration, AI-powered tools, and integrated streaming API services.",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js server/ public/js/",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js server/ public/js/ --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "validate:env": "node scripts/validateEnvironment.js",
    "prelaunch": "npm run validate:env && npm test && npm run lint",
    "docker:build": "docker build -t creatorsync .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:init": "node scripts/initDatabase.js",
    "health": "node scripts/healthCheck.js"
  },
  "keywords": [
    "music",
    "beats",
    "producer",
    "artist",
    "monetization",
    "collaboration",
    "real-time"
  ],
  "author": "Demond Balentine <balentinetechsolutions@gmail.com>",
  "license": "PROPRIETARY",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts",
    "music-metadata": "^11.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "globals": "^17.3.0"
  }
}
